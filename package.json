{
  "name": "paintfinity_painting_station",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --port 3005 index.html",
    "build": "bun run ./scripts/build.ts",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:scripts": "bunx tsc -p scripts/tsconfig.json --noEmit",
    "lint": "eslint .",
    "ui": "bunx shadcn@latest add"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.0.14",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
